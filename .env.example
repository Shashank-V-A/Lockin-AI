# Database (Neon PostgreSQL)
# Use Neon's *pooled* connection string (host contains "-pooler") for serverless/Next.js.
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"

# Auth.js
# Google Cloud Console → OAuth client → add this exact redirect URI:
#   http://localhost:3000/api/auth/callback/google
# Authorised JavaScript origin:
#   http://localhost:3000
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Groq (OpenAI-compatible API)
GROQ_API_KEY=""
GROQ_MODEL="llama-3.3-70b-versatile"

# UploadThing
UPLOADTHING_TOKEN=""

# Upstash Redis (rate limiting + dashboard cache)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Code execution sandbox
# Self-hosted Piston (docker-compose) or public fallback:
PISTON_API_URL="http://localhost:2000/api/v2/piston"
# CODE_RUNNER="auto"   # auto | piston | judge0 | local
# DISABLE_PISTON="true"

# Self-hosted Judge0 (optional — takes priority when CODE_RUNNER=judge0 or auto with URL set)
# JUDGE0_API_URL="http://localhost:2358"
# JUDGE0_API_KEY=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Lockin-AI"
