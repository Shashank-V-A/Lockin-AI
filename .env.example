# Database (Neon PostgreSQL)
# Use Neon's *pooled* connection string (host contains "-pooler") for serverless/Next.js.
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=verify-full"

# Auth.js
# Google Cloud Console → OAuth client → add this exact redirect URI:
#   http://localhost:3000/api/auth/callback/google
# Authorised JavaScript origin:
#   http://localhost:3000
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Groq (OpenAI-compatible API)
GROQ_API_KEY=""
GROQ_MODEL="llama-3.3-70b-versatile"

# UploadThing
UPLOADTHING_TOKEN=""

# Upstash Redis (required in production for rate limits + dashboard cache)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
# Production: Redis is required by default. Set only for single-instance dev/staging:
# ALLOW_MEMORY_RATE_LIMIT="true"

# Cron secret for /api/cron/resume-worker (Vercel cron or external scheduler)
CRON_SECRET="generate-with-openssl-rand-base64-32"

# Code execution sandbox
# Local: docker compose up piston -d && npm run piston:setup
PISTON_API_URL="http://localhost:2000/api/v2"
# PISTON_API_TOKEN=""  # Required for emkc.org public API (whitelist as of Feb 2026)
CODE_RUNNER="auto"
# Production (Vercel): use Judge0 CE — public Piston execute is whitelist-only
# JUDGE0_API_URL="https://ce.judge0.com"
# DISABLE_LOCAL_CODE_EXEC="true"

# Optional observability
# SENTRY_DSN=""

# App (production)
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"
NEXT_PUBLIC_APP_NAME="Lockin-AI"

# Production code execution — Judge0 CE (Piston public API is whitelist-only since Feb 2026)
# JUDGE0_API_URL="https://ce.judge0.com"
# CODE_RUNNER="auto"
# DISABLE_LOCAL_CODE_EXEC="true"
